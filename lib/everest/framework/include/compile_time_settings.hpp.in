#ifndef FRAMEWORK_COMPILE_TIME_SETTINGS_HPP
#define FRAMEWORK_COMPILE_TIME_SETTINGS_HPP

#cmakedefine CMAKE_INSTALL_PREFIX "@CMAKE_INSTALL_PREFIX@"
#cmakedefine CMAKE_INSTALL_LIBDIR "@CMAKE_INSTALL_LIBDIR@"

#ifndef CMAKE_INSTALL_PREFIX
#define EVEREST_INSTALL_PREFIX ("/usr")
#else
#define EVEREST_INSTALL_PREFIX (CMAKE_INSTALL_PREFIX)
#endif

#ifndef CMAKE_INSTALL_LIBDIR
#define EVEREST_INSTALL_LIBDIR ("lib")
#else
#define EVEREST_INSTALL_LIBDIR (CMAKE_INSTALL_LIBDIR)
#endif

// FIXME (aw): this could be also compile time selectable
#define EVEREST_NAMESPACE ("everest")

#define EVEREST_FRAMEWORK_THREAD_POOL_SCALING_POLICY_LATENCY 1
#define EVEREST_FRAMEWORK_THREAD_POOL_SCALING_POLICY_GREEDY 2
#define EVEREST_FRAMEWORK_THREAD_POOL_SCALING_POLICY_CONSERVATIVE 3
#define EVEREST_FRAMEWORK_THREAD_POOL_SCALING_POLICY_FIXED_SIZE 4
#define EVEREST_FRAMEWORK_THREAD_POOL_SCALING_POLICY_CUSTOM 5

#define EVEREST_FRAMEWORK_THREAD_POOL_SCALING_POLICY @EVEREST_FRAMEWORK_THREAD_POOL_SCALING_POLICY_ID@
#define EVEREST_FRAMEWORK_THREAD_POOL_SCALING_LATENCY_THRESHOLD_MS @EVEREST_FRAMEWORK_THREAD_POOL_SCALING_LATENCY_THRESHOLD_MS@
#define EVEREST_FRAMEWORK_THREAD_POOL_SCALING_LATENCY_TICK_MS @EVEREST_FRAMEWORK_THREAD_POOL_SCALING_LATENCY_TICK_MS@
#define EVEREST_FRAMEWORK_THREAD_POOL_SCALING_FIXED_SIZE_THRESHOLD @EVEREST_FRAMEWORK_THREAD_POOL_SCALING_FIXED_SIZE_THRESHOLD@
#define EVEREST_FRAMEWORK_THREAD_POOL_SCALING_POLICY_CUSTOM_TYPE @EVEREST_FRAMEWORK_THREAD_POOL_SCALING_POLICY_CUSTOM_TYPE_CONFIG@

#if EVEREST_FRAMEWORK_THREAD_POOL_SCALING_POLICY == EVEREST_FRAMEWORK_THREAD_POOL_SCALING_POLICY_CUSTOM
#include <@EVEREST_FRAMEWORK_THREAD_POOL_SCALING_POLICY_CUSTOM_HEADER_CONFIG@>
#endif

#endif // FRAMEWORK_COMPILE_TIME_SETTINGS_HPP
