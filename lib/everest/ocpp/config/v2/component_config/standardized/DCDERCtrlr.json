{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Schema for DCDERCtrlr",
  "name": "DCDERCtrlr",
  "type": "object",
  "properties": {
    "DCDERCtrlrAvailable": {
      "variable_name": "Available",
      "characteristics": {
        "supportsMonitoring": true,
        "dataType": "boolean"
      },
      "attributes": [
        {
          "type": "Actual",
          "mutability": "ReadOnly",
          "value": false
        }
      ],
      "description": "Whether DC DER control is supported by this EVSE. When true, the Charging Station supports configuring DER control settings for the DC inverter of this EVSE.",
      "default": false,
      "type": "boolean"
    },
    "DCDERCtrlrModesSupported": {
      "variable_name": "ModesSupported",
      "characteristics": {
        "valuesList": "EnterService,FreqDroop,FreqWatt,FixedPFAbsorb,FixedPFInject,FixedVar,Gradients,HFMustTrip,HFMayTrip,HVMustTrip,HVMomCess,HVMayTrip,LimitMaxDischarge,LFMustTrip,LVMustTrip,LVMomCess,LVMayTrip,PowerMonitoringMustTrip,VoltVar,VoltWatt,WattPF,WattVar",
        "supportsMonitoring": true,
        "dataType": "MemberList"
      },
      "attributes": [
        {
          "type": "Actual",
          "mutability": "ReadOnly"
        }
      ],
      "description": "List of DER control modes supported by the DC inverter of this EVSE. These represent the DER capabilities (nameplate information) of the EVSE inverter.",
      "type": "string"
    }
  },
  "required": []
}
