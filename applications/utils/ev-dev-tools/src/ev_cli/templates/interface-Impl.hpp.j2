{% from "helper_macros.j2" import handle_cmd_signature, print_template_info, insert_block, cpp_type, print_license_header %}
{{ print_license_header(info.license_header) }}
#ifndef {{ info.hpp_guard }}
#define {{ info.hpp_guard }}

{{ print_template_info('3', 'marked regions will be kept') }}

#include <{{ info.base_class_header }}>

#include "{{ info.module_header }}"

{{ insert_block(info.blocks.add_headers) }}

namespace module {
namespace {{ info.interface_implementation_id }} {

struct RwConf {
    {% for item in info.rwconfig %}
    {{ cpp_type(item) }} {{ item.name }};
    {% endfor %}
};

{% for item in info.rwconfig %}
{% if loop.first %}
struct RwConfUpdate {
    using ConfigChangeResult = Everest::config::ConfigChangeResult;

    virtual ~RwConfUpdate() = default;

    // override in class {{ info.class_name }} adding the implementation to {{ info.class_name }}.cpp
    // or inline
    // e.g.
    // ConfigChangeResult on_{{ item.name }}_changed(const {{ cpp_type(item) }}& value) override {
    //     rw_config.{{ item.name }} = value;
    //     return ConfigChangeResult::Accepted();
    // }

{% endif %}
    virtual ConfigChangeResult on_{{ item.name }}_changed(const {{ cpp_type(item) }}& /* value */) {
        return ConfigChangeResult::Rejected("handler not implemented");
    }
{% if loop.last %}
};
{% endif %}
{% endfor %}

struct Conf {
    {% for item in info.config %}
    {{ cpp_type(item) }} {{ item.name }};
    {% endfor %}

    {% for item in info.rwconfig %}
    const {{ cpp_type(item) }}& {{ item.name }};
    {% endfor %}

    {% for item in info.rwconfig %}
    {% if loop.first %}
    Conf(const RwConf& rw):
    {% endif %}
    {% if loop.last %}
    {{ item.name }}(rw.{{ item.name }}) {}
    {% else %}
    {{ item.name }}(rw.{{ item.name }}),
    {% endif %}
    {% else %}
    Conf() = default;
    Conf(const RwConf&) {
    };
    {% endfor %}
};

{% if info.rwconfig|length > 0 %}
class {{ info.class_name }} : public {{ info.class_parent}}, public RwConfUpdate {
{% else %}
class {{ info.class_name }} : public {{ info.class_parent}} {
{% endif %}
public:
    {{ info.class_name }}() = delete;
    {{ info.class_name }}(Everest::ModuleAdapter* ev, const Everest::PtrContainer<{{ info.module_class }}> &mod, {% if info.rwconfig|length > 0 %}Conf& config, RwConf& rw_config{% else %}Conf& config{% endif %}) :
        {{ info.class_parent }}(ev, "{{ info.interface_implementation_id }}"),
        mod(mod),
        {% if info.rwconfig|length > 0 %}
        config(config),
        rw_config(rw_config)
        {% else %}
        config(config)
        {% endif %}
    {};

    {{ insert_block(info.blocks.public_defs, indent=4) }}

protected:
    {% if not cmds %}
    // no commands defined for this interface
    {% else %}
    // command handler functions (virtual)
    {% for cmd in cmds %}
    {{ handle_cmd_signature(cmd, none, '::'+info.interface) }} override;
    {% endfor %}
    {% endif %}

    {{ insert_block(info.blocks.protected_defs, indent=4) }}

private:
    const Everest::PtrContainer<{{ info.module_class }}>& mod;
    const Conf& config;
    {% if info.rwconfig|length > 0 %}
    RwConf& rw_config;
    {% endif %}

    virtual void init() override;
    virtual void ready() override;
    void shutdown() override;

    {{ insert_block(info.blocks.private_defs, indent=4) }}
};

{{ insert_block(info.blocks.after_class) }}

} // namespace {{ info.interface_implementation_id }}
} // namespace module

#endif // {{ info.hpp_guard }}
